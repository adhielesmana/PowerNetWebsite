# Copy this file to .env and update values before running deploy.sh in production.
# Do NOT commit .env itself; it already lives in .gitignore.

# Set this to 'production' to trigger the hostname/SSL prompts.
DEPLOY_ENV=development

# The FQDN that will appear in the generated nginx server block.
PRODUCTION_HOSTNAME=powernet.example.com

# Set to true if you want a self-signed certificate to be created.
PRODUCTION_ENABLE_SSL=true

# Optional overrides below (defaults are already defined inside deploy.sh)
HOST_NGINX_ROOT=/var/www/powernet-site
HOST_NGINX_CONF=/etc/nginx/conf.d/powernet-site.conf
HOST_SSL_CERT_DIR=/etc/ssl/powernet
DOCKER_PORT=8080
